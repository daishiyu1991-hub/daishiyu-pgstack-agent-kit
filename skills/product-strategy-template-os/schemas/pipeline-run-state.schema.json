{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/product-strategy-template-os/pipeline-run-state.schema.json",
  "title": "Pipeline Run State",
  "type": "object",
  "required": ["artifact", "created_at", "chapter_order", "chapters"],
  "properties": {
    "artifact": { "const": "pipeline_run_state_v1" },
    "created_at": { "type": "string" },
    "run": { "type": "string" },
    "category": { "type": "string" },
    "marketplace": { "type": "string" },
    "purpose": { "type": "string" },
    "architecture_refs": { "type": "array", "items": { "type": "string" } },
    "global_rule_refs": { "type": "array", "items": { "type": "string" } },
    "chapter_order": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "checklist_definition": { "type": "array", "items": { "type": "string" } },
    "chapters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["chapter", "status"],
        "properties": {
          "chapter": { "type": "string" },
          "status": { "type": "string" },
          "primary_plan": { "type": "string" },
          "primary_report": { "type": "string" },
          "decision_record": { "type": "string" },
          "process_refs": { "type": "array", "items": { "type": "string" } },
          "checkpoints": { "type": "object", "additionalProperties": { "type": "string" } },
          "open_gaps": { "type": "array", "items": { "type": "string" } },
          "human_decision_options": { "type": "array", "items": { "type": "string" } },
          "pause_state": { "type": "object" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
