# Copy values into your shell profile or agent environment if useful.

export PGSTACK_HOME="$HOME/Documents/PGStack/personal-gstack"
export CODEX_HOME="$HOME/.codex"
export HERMES_HOME="$HOME/.hermes"
export PGSTACK_HERMES_JOBS_PATH="$HERMES_HOME/cron/jobs.json"

# Optional integrations. Keep secrets out of git.
export PGSTACK_FEISHU_DM_CHANNEL=""
export PGSTACK_MEMTENSOR_MODE="local"
export PGSTACK_NOTEBOOKLM_MODE="manual-sidecar"

