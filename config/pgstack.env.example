# Copy values into your shell profile or agent environment if useful.

export PGSTACK_HOME="$HOME/Documents/PGStack/personal-gstack"
export CODEX_HOME="$HOME/.codex"
export HERMES_HOME="$HOME/.hermes"
export PGSTACK_HERMES_JOBS_PATH="$HERMES_HOME/cron/jobs.json"

# Optional integrations. Keep secrets out of git.
export PGSTACK_FEISHU_DM_CHANNEL=""
export PGSTACK_MEMTENSOR_MODE="local"
export PGSTACK_NOTEBOOKLM_MODE="manual-sidecar"

# Optional Central Brain Host. Keep real SSH targets and key paths local.
export PGSTACK_CENTRAL_BRAIN_SSH_TARGET=""
export PGSTACK_CENTRAL_BRAIN_SSH_KEY=""
export PGSTACK_CENTRAL_BRAIN_CONTAINER="hermes-admin"
export PGSTACK_CENTRAL_BRAIN_GBRAIN_BIN="/opt/data/.bun/bin/gbrain"
export PGSTACK_CENTRAL_BRAIN_GBRAIN_CWD="/opt/data/gbrain"
export PGSTACK_CENTRAL_BRAIN_MEMORY_OWNER="central"
export PGSTACK_CENTRAL_BRAIN_TIMEOUT="30"
export PGSTACK_CENTRAL_BRAIN_SMOKE_MARKER=""
